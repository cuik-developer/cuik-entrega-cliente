# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cuik

# Auth
BETTER_AUTH_SECRET=your-secret-minimum-32-characters-long-change-this
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=

# Apple Wallet — Platform-level (same for all tenants)
APPLE_TEAM_ID=
APPLE_PASS_TYPE_ID=pass.cuik.org
APPLE_SIGNER_KEY_BASE64=
APPLE_SIGNER_CERT_BASE64=
APPLE_SIGNER_KEY_PASSPHRASE=
APPLE_WWDR_BASE64=
APPLE_AUTH_SECRET=

# Apple Web Service Protocol — Base URL for Apple Wallet callbacks
# Example: https://app.cuik.org/api/apple-wallet
APPLE_WEBSERVICE_URL=

# Apple APNs — Push notifications to update passes
APPLE_APNS_KEY_ID=
APPLE_APNS_TEAM_ID=
APPLE_APNS_P8_BASE64=
APPLE_APNS_TOPIC=pass.cuik.org

# Google Wallet — Platform-level
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_JSON_B64=

# Email
RESEND_API_KEY=
# Sender address for transactional emails (default: Cuik <onboarding@resend.dev>)
# In production, set to your verified domain (e.g. "Cuik <no-reply@cuik.org>")
EMAIL_FROM="Cuik <onboarding@resend.dev>"
# Override all email recipients in dev (Resend test mode only allows your own email)
# EMAIL_TEST_TO=your-email@example.com
# Super Admin email for notifications (new solicitudes, etc.)
SA_EMAIL=admin@cuik.org

# Storage — MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=cuik_minio
MINIO_SECRET_KEY=cuik_minio_secret
MINIO_BUCKET=cuik-assets
# Set to true if MinIO uses HTTPS (default: false for local dev)
MINIO_USE_SSL=false
# Docker-compose credentials (used by docker/docker-compose.yml)
MINIO_ROOT_USER=cuik_minio
MINIO_ROOT_PASSWORD=cuik_minio_secret

# Redis
REDIS_URL=redis://localhost:6379

# AI — Gemini API key for nano-banana asset generation
GEMINI_API_KEY=

# Encryption key for tenant Apple certificates (hex-encoded 32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Cron — Secret for authenticating cron API routes (analytics, campaigns scheduler)
CRON_SECRET=change-this-to-a-random-secret
