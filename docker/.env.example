# Database
DATABASE_URL=postgresql://cuik:cuik_dev@localhost:5432/cuik_dev

# Authentication (Better Auth)
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# MinIO / S3 (Object Storage for pass assets)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=cuik_minio
MINIO_SECRET_KEY=cuik_minio_secret
MINIO_BUCKET=cuik-assets

# Apple Wallet
APPLE_PASS_TYPE_ID=pass.com.cuik.loyalty
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_PASS_CERTIFICATE_PATH=./certs/pass.pem
APPLE_PASS_KEY_PATH=./certs/pass-key.pem

# Google Wallet
GOOGLE_WALLET_ISSUER_ID=YOUR_ISSUER_ID
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=./certs/google-service-account.json

# AI Features (optional)
OPENAI_API_KEY=your-openai-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
